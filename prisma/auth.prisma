generator client {
  provider = "prisma-client-js"
  output   = "../generated/auth-client"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum WorkMode {
  ONLINE
  OFFLINE
}

model User {
  id                     String           @id @default(cuid())
  username               String           @unique
  passwordHash           String
  fullName               String
  email                  String?
  phone                  String?
  address                String?
  department             String?
  workStartTime          String?
  workEndTime            String?
  lateGraceMinutes       Int              @default(5)
  earlyLeaveGraceMinutes Int              @default(5)
  breakPolicyJson        String           @default("{\"wc\":{\"maxCount\":3,\"maxMinutesEach\":10},\"smoke\":{\"maxCount\":2,\"maxMinutesEach\":10},\"meal\":{\"maxCount\":2,\"maxMinutesEach\":40}}")
  workMode               WorkMode         @default(OFFLINE)
  allowedOffDaysPerMonth Int              @default(2)
  annualLeaveQuota       Int              @default(15)
  role                   Role             @default(EMPLOYEE)
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?
  authSessions           AuthSession[]
  loginAccessLogs        LoginAccessLog[]

  @@index([isActive, deletedAt])
  @@index([deletedAt, role])
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  tokenHash        String   @unique
  ipAddress        String
  userAgent        String?
  deviceKey        String
  isSharedIp       Boolean  @default(false)
  isSharedDevice   Boolean  @default(false)
  appInstance      String?  
  revokedAt        DateTime?
  revokedReason    String?
  expiresAt        DateTime
  lastSeenAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt, lastSeenAt])
  @@index([deviceKey])
  @@index([ipAddress])
  @@index([expiresAt])
  @@index([revokedAt])
}

model LoginAccessLog {
  id             String   @id @default(cuid())
  userId         String?
  usernameInput  String
  ipAddress      String
  userAgent      String?
  deviceKey      String
  success        Boolean
  blockedReason  String?
  failedReason   String?
  isSharedIp     Boolean  @default(false)
  isSharedDevice Boolean  @default(false)
  appInstance    String?
  createdAt      DateTime @default(now())

  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([ipAddress, usernameInput, success, createdAt])
  @@index([success, deviceKey, userId])
  @@index([success, ipAddress, userId, createdAt])
}

model LoginSecurityConfig {
  id                              Int      @id
  enforceSingleDevicePerAccount   Boolean  @default(true)
  enforceSingleAccountPerDeviceIp Boolean  @default(true)
  blockMobilePhoneLogin           Boolean  @default(true)
  updatedAt                       DateTime @updatedAt
}
